<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude sensitive local intelligence vaults and API key settings from cloud backup -->
        <exclude domain="database" path="kosh_vault.db" />
        <exclude domain="sharedpref" path="neural_core_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <!-- Exclude sensitive local intelligence vaults and API key settings from device transfer -->
        <exclude domain="database" path="kosh_vault.db" />
        <exclude domain="sharedpref" path="neural_core_prefs.xml" />
    </device-transfer>
</data-extraction-rules>